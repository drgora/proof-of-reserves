# Copy to .env and fill in. docker compose reads .env automatically.

# Required: your Zerion API key (the prover service queries Zerion with it).
ZERION_API_KEY=

# Minimum balance (USD) the verifier will accept.
POR_REQUIRED_THRESHOLD=1000000

# LOCAL TESTING ONLY: set to 1 to prove any address without a wallet/SIWE
# (enables POST /api/admin/prove + the UI's admin panel). Leave empty otherwise.
POR_ADMIN_MODE=
